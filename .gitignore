# ======================================================================
# Git Ignore
# ======================================================================
# Purpose: Prevent build artifacts, local config, and sensitive
#          credentials from entering version control.
# Docs: https://git-scm.com/docs/gitignore
# ======================================================================

# ----------------------------------------------------------------------
# Dependency Managers (Node)
# ----------------------------------------------------------------------
node_modules/
.pnp/
.pnp.*

# Yarn 2+ Zero-Installs support
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----------------------------------------------------------------------
# Php (Backend)
# ----------------------------------------------------------------------
vendor/

# ----------------------------------------------------------------------
# Secrets & Security
# ----------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
.vercel

# ----------------------------------------------------------------------
# Build & Compilation Output
# ----------------------------------------------------------------------
.next/
dist/
build/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ----------------------------------------------------------------------
# Testing & Debugging
# ----------------------------------------------------------------------
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------------------------------------------------------
# Editor & Ide Settings
# ----------------------------------------------------------------------
.idea/

# ----------------------------------------------------------------------
# System & Os Junk
# ----------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------------------------------
# Seo & Generated Data
# ----------------------------------------------------------------------
/public/robots.txt
/public/sitemap*
*sitemap*.xml
.env*.local
