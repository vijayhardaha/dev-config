# ======================================================================
# Prettier Ignore
# ======================================================================
# Purpose: Tell Prettier which files to skip to avoid formatting
#          generated or binary files (keeps diffs small and fast).
# Docs: https://prettier.io/docs/ignore
# ======================================================================

# ----------------------------------------------------------------------
# Project & Build Artifacts
# ----------------------------------------------------------------------
.next/
.idea/
.husky/
.vercel/
.git/
node_modules/
build/
dist/
out/

# ----------------------------------------------------------------------
# Package Manager Lockfiles
# ----------------------------------------------------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lock

# ----------------------------------------------------------------------
# Static Assets & Public Data
# ----------------------------------------------------------------------
public/
vendor/
assets/
static/

# ----------------------------------------------------------------------
# Minified & Generated Files
# ----------------------------------------------------------------------
*.min.js
*.min.css
*.min.map

# ----------------------------------------------------------------------
# Environment & Config
# ----------------------------------------------------------------------
.env
.env.*
.editorconfig

# ----------------------------------------------------------------------
# Logs & Cache
# ----------------------------------------------------------------------
*.log
npm-debug.log*
.cache
