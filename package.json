{
  "name": "@vijayhardaha/dev-config",
  "version": "1.1.2",
  "description": "Reusable development configurations for Next.js + TypeScript projects",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write --log-level error .",
    "format:check": "prettier --check --log-level error .",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gc": "read -p 'Execute git commands from .tmp/git.txt? [Y/n] ' ans; [ \"$ans\" = \"n\" ] || [ \"$ans\" = \"N\" ] && echo 'Aborted.' || source .tmp/git.txt",
    "prepare": "husky"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "license": "MIT",
  "type": "module",
  "main": "./src/index.js",
  "homepage": "https://github.com/vijayhardaha/dev-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/dev-config.git"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/dev-config/issues"
  },
  "exports": {
    ".": "./src/index.js",
    "./eslint": "./src/eslint/index.js",
    "./eslint/ts": "./src/eslint/typescript.js",
    "./eslint/react": "./src/eslint/react.js",
    "./eslint/next": "./src/eslint/next.js",
    "./prettier": "./src/prettier/index.js",
    "./commitlint": "./src/commitlint/index.js",
    "./stylelint": "./src/stylelint/index.js",
    "./next-sitemap": "./src/next-sitemap/index.js",
    "./tsconfig": "./src/tsconfig/index.json",
    "./jsconfig": "./src/jsconfig/index.json"
  },
  "keywords": [
    "config",
    "devtools",
    "eslint",
    "prettier",
    "commitlint",
    "stylelint",
    "next-sitemap",
    "typescript"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/types": "^20.5.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "next-sitemap": "^4.2.3",
    "release-it": "^20.0.1",
    "stylelint": "^17.11.0",
    "stylelint-config-property-sort-order-smacss": "^11.2.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@eslint/compat": ">=2",
    "@eslint/eslintrc": ">=3",
    "@eslint/js": ">=9",
    "@prettier/plugin-xml": ">=3",
    "@typescript-eslint/eslint-plugin": ">=8",
    "@typescript-eslint/parser": ">=8",
    "eslint-config-prettier": ">=10",
    "eslint-import-resolver-typescript": ">=4",
    "eslint-plugin-import": ">=2",
    "eslint-plugin-jsdoc": ">=62",
    "eslint-plugin-prettier": ">=5",
    "eslint": ">=9",
    "globals": ">=17",
    "husky": ">=9",
    "prettier": ">=3",
    "typescript": ">=6"
  },
  "peerDependenciesMeta": {
    "@commitlint/cli": {
      "optional": true
    },
    "@commitlint/config-conventional": {
      "optional": true
    },
    "@commitlint/types": {
      "optional": true
    },
    "@next/eslint-plugin-next": {
      "optional": true
    },
    "eslint-config-next": {
      "optional": true
    },
    "eslint-plugin-jsx-a11y": {
      "optional": true
    },
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "next-sitemap": {
      "optional": true
    },
    "stylelint": {
      "optional": true
    },
    "stylelint-config-property-sort-order-smacss": {
      "optional": true
    },
    "stylelint-config-standard-scss": {
      "optional": true
    },
    "stylelint-order": {
      "optional": true
    }
  },
  "overrides": {
    "undici": "^7.0.0"
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
